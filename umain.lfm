      object GroupBox1: TGroupBox
        Left = 0
        Height = 498
        Top = 77
        Width = 546
        Align = alClient
        ClientHeight = 495
        ClientWidth = 542
        TabOrder = 1
        object lbl_info: TLabel
          Left = 20
          Height = 455
          Top = 20
          Width = 502
          Align = alClient
          AutoSize = False
          BidiMode = bdRightToLeftNoAlign
          BorderSpacing.Around = 20
          Caption = 'Editar no Linux com a versão gratuita do DaVinci Resolve não deveria ser uma dor de cabeça. Percebendo que muitos editores perdiam horas tentando contornar problemas de compatibilidade ou recorrendo a sites de conversão pouco seguros, Duan Lee iniciou o Synapse.'#10#10'Mais do que um simples conversor, o Synapse é um elo entre a web e a sua timeline. O objetivo é garantir que o editor foque no que importa: a criatividade. O projeto transforma arquivos complexos em formatos amigáveis para o software da Blackmagic, garantindo eficiência técnica e segurança de dados. Como um projeto de código aberto, o Synapse está em constante evolução, buscando se tornar o canivete suíço definitivo para qualquer editor de vídeo que escolheu o Linux como sua estação de trabalho.'
          Color = clNone
          Font.Height = -13
          Font.Name = 'Noto Sans'
          ParentBidiMode = False
          ParentColor = False
          ParentFont = False
          WordWrap = True
        end
      end
      object Label5: TLabel
        Left = 20
        Height = 37
        Top = 20
        Width = 853
        Align = alTop
        Alignment = taCenter
        BorderSpacing.Around = 20
        Caption = 'Sobre o Software Synapse'
        Color = clNone
        Font.Height = -27
        Font.Name = 'Sans'
        ParentColor = False
        ParentFont = False
      end
    end
  end
